{
  "name": "mfe-analyzer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "build:cli": "esbuild cli/index.ts --bundle --platform=node --format=esm --outfile=cli/analyze.mjs --alias:@=./src",
    "analyze": "npm run build:cli --silent && node cli/analyze.mjs"
  },
  "dependencies": {
    "@babel/parser": "^7.29.7",
    "@dagrejs/dagre": "^1.1.4",
    "@xyflow/react": "^12.3.6",
    "lucide-react": "^0.446.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
